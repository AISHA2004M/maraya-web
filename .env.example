# Copy this to backend/.env and fill in real values
PROJECT_NAME=Virtual Try-On API
API_V1_STR=/api/v1

# Database (Docker default)
DATABASE_URL=postgresql://vrital:vrital_pass@db:5432/vrital_db

# JWT
JWT_SECRET=change_me_super_secret_key_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Redis
REDIS_URL=redis://redis:6379/0

# S3 (optional, leave blank for local dev)
S3_BUCKET=vrital-bucket
S3_ACCESS_KEY=your_aws_access_key
S3_SECRET_KEY=your_aws_secret_key

# AI Service URL (replace with real inference endpoint)
AI_SERVICE_URL=http://localhost:8001
